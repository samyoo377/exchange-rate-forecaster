NODE_ENV=development
PORT=4001

# ── MySQL ──
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=exchange_rate_forecaster
DATABASE_URL="mysql://root@127.0.0.1:3306/exchange_rate_forecaster"

# ── AI API ──
ABL_API_BASE_URL=https://api.ablai.top
ABL_API_TOKEN=your_token_here
ADMIN_MODEL_ID=claude-sonnet-4-6
ADMIN_MODEL_LIST=claude-sonnet-4-6,gpt-5.4-2026-03-05,gemini-3.1-pro-preview-thinking-high

# ── App ──
ALPHA_VANTAGE_API_KEY=your_key_here
DEFAULT_SYMBOL=USDCNH
DEFAULT_HORIZON=T+2
DATA_IMPORT_DEFAULT_PATH=./USDCNH-BBG-20Days.xlsx
CRON_REFRESH="0 18 * * 1-5"

# ── Rate Data (xxx) ──
RATE_DATA_M_ID=your_m_id_here
RATE_DATA_MERCHANT_ID=your_merchant_id_here
RATE_DATA_SIGN_BUSINESS_ID=your_sign_business_id_here
RATE_DATA_COOKIE=your_cookie_here
RATE_DATA_DOMAIN=xxx
