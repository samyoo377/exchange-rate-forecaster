{
  "name": "exchange-rate-forecaster-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev:server": "pnpm --filter exchange-rate-server dev",
    "dev:web": "pnpm --filter exchange-rate-web dev",
    "dev:admin": "pnpm --filter exchange-rate-admin dev",
    "db:generate": "pnpm --filter exchange-rate-server db:generate",
    "db:push": "pnpm --filter exchange-rate-server db:push",
    "db:seed": "pnpm --filter exchange-rate-server db:seed",
    "setup": "pnpm install && pnpm db:generate && pnpm db:push",
    "start:all": "bash ./scripts/start-all.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "vue-demi",
      "vue-echarts"
    ]
  },
  "devDependencies": {
    "prisma": "5.22.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}
