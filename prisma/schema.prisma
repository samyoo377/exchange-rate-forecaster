generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model RawMarketData {
  id           String   @id @default(cuid())
  source       String
  symbol       String
  payload      String   @db.Text
  fetchedAt    DateTime
  status       String
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
}

model NormalizedMarketSnapshot {
  id           String   @id @default(cuid())
  symbol       String
  snapshotDate DateTime
  open         Float
  high         Float
  low          Float
  close        Float
  volume       Float?
  source       String
  version      String
  createdAt    DateTime @default(now())

  @@unique([symbol, snapshotDate, version])
}

model InsightSummary {
  id           String   @id @default(cuid())
  symbol       String
  summaryTitle String
  summaryText  String   @db.Text
  drivers      String   @db.Text
  tags         String   @db.Text
  sourceRefs   String   @db.Text
  createdAt    DateTime @default(now())
}

model PredictionResult {
  id                 String   @id @default(cuid())
  symbol             String
  userQuery          String   @db.Text
  horizon            String
  direction          String
  confidence         Float
  rationale          String   @db.Text
  riskNotes          String   @db.Text
  modelVersion       String
  dataSnapshotRefs   String   @db.Text
  signalsSnapshot    String?  @db.Text
  indicatorsSnapshot String?  @db.Text
  createdAt          DateTime @default(now())

  @@index([symbol, createdAt])
}

model TaskRunLog {
  id           String    @id @default(cuid())
  taskType     String
  status       String
  inputRef     String?   @db.Text
  outputRef    String?   @db.Text
  startedAt    DateTime
  finishedAt   DateTime?
  errorMessage String?   @db.Text
  createdAt    DateTime  @default(now())
}

model NewsRawItem {
  id          String    @id @default(cuid())
  source      String
  title       String
  url         String
  summary     String?   @db.Text
  publishedAt DateTime?
  fetchedAt   DateTime  @default(now())
  category    String?
  createdAt   DateTime  @default(now())

  @@unique([url])
}

model NewsDigest {
  id           String   @id @default(cuid())
  digestDate   DateTime @default(now())
  symbol       String   @default("USDCNH")
  headline     String
  summary      String   @db.Text
  keyFactors   String   @db.Text
  sentiment    String
  rawItemIds   String   @db.Text
  modelVersion String
  createdAt    DateTime @default(now())
}

// ── Feature 1: Chat History + File Upload ──

model ChatSession {
  id        String        @id @default(cuid())
  scope     String        // "web" | "admin"
  title     String?
  symbol    String        @default("USDCNH")
  horizon   String        @default("T+2")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([scope, updatedAt])
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String      // "user" | "assistant" | "system"
  content     String      @db.MediumText
  attachments String?     @db.Text // JSON array of UploadedFile ids
  createdAt   DateTime    @default(now())

  @@index([sessionId, createdAt])
}

model UploadedFile {
  id           String   @id @default(cuid())
  originalName String
  storedPath   String
  mimeType     String
  sizeBytes    Int
  sessionId    String?
  createdAt    DateTime @default(now())
}

// ── Feature 2: News Source Management ──

model NewsSource {
  id              String    @id @default(cuid())
  name            String    @unique
  url             String
  type            String    // "rss" | "json-api" | "twitter"
  category        String    // "forex" | "finance" | "economy" | "macro" | "social"
  enabled         Boolean   @default(true)
  fetchIntervalMs Int       @default(60000)
  lastFetchedAt   DateTime?
  lastError       String?   @db.Text
  parseConfig     String?   @db.Text // JSON custom parse rules
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  fetchLogs       NewsFetchLog[]
}

model NewsFetchLog {
  id              String    @id @default(cuid())
  sourceId        String
  source          NewsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceName      String
  requestUrl      String    @db.Text
  requestMethod   String    @default("GET")
  responseStatus  Int?
  responseBody    String?   @db.MediumText
  fetchedCount    Int       @default(0)
  success         Boolean   @default(false)
  error           String?   @db.Text
  startedAt       DateTime
  finishedAt      DateTime?
  durationMs      Int?
  createdAt       DateTime  @default(now())

  @@index([sourceId, createdAt])
}

// ── Feature 3: Indicator Configuration ──

model IndicatorGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  indicators  IndicatorConfig[]
}

model IndicatorConfig {
  id                String   @id @default(cuid())
  indicatorType     String   @unique
  displayName       String
  description       String?  @db.Text
  category1         String   @default("custom")
  category2         String?
  category3         String?
  groupId           String?
  group             IndicatorGroup? @relation(fields: [groupId], references: [id])
  formulaLatex      String?  @db.Text
  formulaExpression String?  @db.Text
  stepFormulas      String?  @db.Text
  params            String   @db.Text
  signalThresholds  String   @db.Text
  enabled           Boolean  @default(true)
  weight            Float    @default(1.0)
  chartType         String   @default("line")
  subChart          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([category1, category2])
  @@index([groupId])
}
